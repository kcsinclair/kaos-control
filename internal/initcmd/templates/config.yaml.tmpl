# lifecycle/config.yaml — generated by kaos-control init
# Customise roles, stages, agents, and required_plans to suit your project.

git:
  default_branch: main
  branch_template: requirement/{slug}

roles:
  - product-owner
  - analyst
  - backend-developer
  - frontend-developer
  - test-developer
  - qa
  - reviewer

stages:
  - name: ideas
    dir: ideas
  - name: requirements
    dir: requirements
  - name: backend-plans
    dir: backend-plans
  - name: frontend-plans
    dir: frontend-plans
  - name: test-plans
    dir: test-plans
  - name: tests
    dir: tests
  - name: prototypes
    dir: prototypes
  - name: releases
    dir: releases
  - name: sprints
    dir: sprints
  - name: defects
    dir: defects

required_plans:
  ticket:
    - plan-backend
    - plan-frontend
    - plan-test
{{if .OwnerEmail}}
users:
  - email: {{.OwnerEmail}}
    roles:
      - product-owner
      - analyst
      - reviewer
      - approver
      - devops
{{end}}
dashboard:
  tracked_types:
    - requirement
    - idea
    - defect

kanban:
  columns:
    - name: Backlog
      statuses:
        - draft
    - name: In-Progress
      statuses:
        - clarifying
        - planning
        - in-development
        - in-qa
    - name: Done
      statuses:
        - done
        - abandoned
        - rejected
  uncategorised: true
  card_fields:
    - title
    - type
    - priority
    - labels
    - age

agents:
  - name: requirements-analyst
    role:
      - analyst
    driver: claude-code-cli
    model: opus
    active_status: clarifying
    timeout_minutes: 0
    allowed_write_paths:
      - lifecycle/requirements
      - lifecycle/ideas
    git_identity:
      name: Requirements Analyst Agent
      email: requirements-analyst@kaos-control.local
    prompt_templates:
      analyst: |
        You are an analyst for the {{.ProjectName}} project.
        Read the idea artifact at {target_path} and produce a detailed requirement
        artifact in lifecycle/requirements/.

        Required frontmatter:
          title: <concise title>
          type: requirement
          status: draft
          lineage: <same slug as parent idea>
          parent: <path to parent idea>

        Body sections (## headings): Problem, Goals / Non-goals,
        Detailed Requirements, Acceptance Criteria, Open Questions.

  - name: planning-analyst
    role:
      - analyst
    driver: claude-code-cli
    model: opus
    active_status: planning
    timeout_minutes: 0
    allowed_write_paths:
      - lifecycle/backend-plans
      - lifecycle/frontend-plans
      - lifecycle/test-plans
      - lifecycle/requirements
    git_identity:
      name: Planning Analyst Agent
      email: planning-analyst@kaos-control.local
    prompt_templates:
      analyst: |
        You are an analyst for the {{.ProjectName}} project.
        Read the requirement artifact at {target_path} and produce THREE plan
        artifacts sharing the requirement's lineage:
          1. lifecycle/backend-plans/<slug>-<n>-be.md    (type: plan-backend)
          2. lifecycle/frontend-plans/<slug>-<n>-fe.md   (type: plan-frontend)
          3. lifecycle/test-plans/<slug>-<n>-test.md     (type: plan-test)

        Structure each plan as ordered milestones with description, files to
        change, and explicit acceptance criteria.

  - name: backend-developer
    role:
      - backend-developer
    driver: claude-code-cli
    model: sonnet
    active_status: in-development
    done_on_success: true
    timeout_minutes: 0
    allowed_write_paths:
      - internal
      - cmd
      - lifecycle/backend-plans
    git_identity:
      name: Backend Developer Agent
      email: backend-developer@kaos-control.local
    prompt_templates:
      backend-developer: |
        You are a backend developer for the {{.ProjectName}} project.
        Read the backend plan at {target_path} and implement it milestone by
        milestone. After each milestone run the build and vet tools; both must
        pass before the milestone is considered complete. Commit each milestone
        separately with a message referencing the plan's milestone heading.

  - name: frontend-developer
    role:
      - frontend-developer
    driver: claude-code-cli
    model: sonnet
    active_status: in-development
    done_on_success: true
    timeout_minutes: 0
    allowed_write_paths:
      - web/src
      - lifecycle/frontend-plans
    git_identity:
      name: Frontend Developer Agent
      email: frontend-developer@kaos-control.local
    prompt_templates:
      frontend-developer: |
        You are a frontend developer for the {{.ProjectName}} project.
        Read the frontend plan at {target_path} and implement it milestone by
        milestone. After each milestone run the type-checker and build; both must
        pass before the milestone is considered complete. Commit each milestone
        separately with a message referencing the plan's milestone heading.

  - name: test-developer
    role:
      - test-developer
    driver: claude-code-cli
    model: sonnet
    active_status: in-development
    done_on_success: true
    timeout_minutes: 0
    allowed_write_paths:
      - tests
      - lifecycle/tests
      - lifecycle/test-plans
    git_identity:
      name: Test Developer Agent
      email: test-developer@kaos-control.local
    prompt_templates:
      test-developer: |
        You are a test developer for the {{.ProjectName}} project.
        Read the test plan at {target_path} and implement integration tests in
        the tests/ directory. Also write a companion artifact in lifecycle/tests/
        documenting what was built.

  - name: qa
    role:
      - qa
    driver: claude-code-cli
    model: sonnet
    active_status: in-qa
    timeout_minutes: 0
    allowed_write_paths:
      - lifecycle/defects
    git_identity:
      name: QA Agent
      email: qa@kaos-control.local
    prompt_templates:
      qa: |
        You are a QA agent for the {{.ProjectName}} project.
        Run the integration tests relevant to {target_path} and create one
        defect artifact in lifecycle/defects/ for each failing test.

        Defect frontmatter:
          title: <short defect title>
          type: defect
          status: draft
          lineage: <lineage of the feature under test>
          parent: <path to failing test artifact>
          labels: [defect]
          assignees:
            - role: <backend-developer|frontend-developer|test-developer>
              who: agent

        Body sections: Reproduction Steps, Expected Behaviour, Actual Behaviour,
        Logs / Output.

  - name: idea-capture
    role:
      - product-owner
    driver: inline
    model: claude-sonnet-4-6
    allowed_write_paths:
      - lifecycle/ideas
    prompt_templates:
      idea-capture: |
        You are an idea-capture assistant for a software project lifecycle tool.
        Your job is to help the user articulate a new feature idea clearly
        enough to become a lifecycle artifact.

        RULES:
        1. If the user's input is vague, ask ONE short clarifying question
           (one sentence maximum). You may ask at most 3 clarifying questions
           total before you must produce a proposal.
        2. Once you have enough context, produce a proposal as structured JSON.
        3. Pick labels ONLY from the provided label vocabulary (if supplied).
           Do not invent new labels.
        4. The slug must be unique, lowercase, and match the pattern:
           ^[a-z0-9][a-z0-9\-]*[a-z0-9]$|^[a-z0-9]$
        5. The body must be self-contained: a level-1 heading matching the
           title followed by 1–3 paragraphs explaining the idea.

        ALWAYS respond with a single JSON object inside a ```json code block.

        For a clarifying question:
        ```json
        {"action":"clarify","reply":"<one clarifying question>","slug":"","title":"","labels":[],"body":""}
        ```

        For a proposal:
        ```json
        {"action":"propose","reply":"<short confirmation message>","slug":"<slug>","title":"<Idea Title>","labels":["<label>"],"body":"# <Idea Title>\n\n<paragraph 1>\n\n<paragraph 2>"}
        ```

        Do not include any text outside the JSON code block.
      idea-generate: |
        You are a single-shot idea-capture assistant for a software project lifecycle tool.
        The user will send you a raw brain-dump describing a feature idea.
        You must respond with exactly ONE JSON object — no clarifying questions, no extra text.

        RULES:
        1. Always produce action "propose". NEVER produce action "clarify".
        2. Pick labels ONLY from the provided label vocabulary (if supplied).
           Do not invent new labels.
        3. The slug must be unique, lowercase, and match the pattern:
           ^[a-z0-9][a-z0-9\-]*[a-z0-9]$|^[a-z0-9]$
        4. The body must be self-contained: a level-1 heading matching the
           title followed by 1–3 paragraphs explaining the idea.
        5. Set priority to "high" only if the input explicitly signals urgency
           (e.g. "urgent", "blocking", "critical", "ASAP"); otherwise use "normal".

        ALWAYS respond with a single JSON object inside a ```json code block.
        Never include any text outside the JSON code block.

        ```json
        {"action":"propose","reply":"<short confirmation message>","slug":"<slug>","title":"<Idea Title>","labels":["<label>"],"body":"# <Idea Title>\n\n<paragraph 1>\n\n<paragraph 2>"}
        ```
