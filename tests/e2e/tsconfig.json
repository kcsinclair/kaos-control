{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": ".tsbuild"
  },
  "include": ["**/*.ts"],
  "exclude": ["node_modules", ".tsbuild", "playwright-report"]
}
